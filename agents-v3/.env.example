# agents-v3 — Trigger.dev V3 pick-generation worker (LOCAL DEV)
#
# Copy to agents-v3/.env and fill in. Used by `npm run dev` / `npm run deploy`
# (Trigger.dev CLI) and read by the generation loop at runtime.
# NEVER commit the filled-in agents-v3/.env — it is gitignored.
#
# In PRODUCTION these are set in Trigger.dev Cloud (Project > Environment
# variables), NOT from this file. This file only powers local `trigger.dev dev`.
#
# In Conductor, scripts/conductor-setup.sh copies your canonical agents-v3/.env
# into every new workspace automatically — fill it in once in the root checkout
# (or $WAGERPROOF_SECRETS_DIR). See .conductor/README.md.

# Trigger.dev CLI auth — per-environment secret key from the Trigger.dev dashboard
TRIGGER_SECRET_KEY=

# LLM providers (the V3 loop is deepseek-reasoner by default; OpenAI is fallback)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Main Supabase (auth / user data / agent ledger) — service role, server-side only
SUPABASE_URL=https://gnjrklxotmbvnxbnnqgq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# CFB Supabase (all sports predictions data: NFL, CFB, NBA, NCAAB, MLB)
CFB_SUPABASE_URL=https://jpxnjuwglavsjbgbasnl.supabase.co
CFB_SUPABASE_ANON_KEY=

# RevenueCat (entitlement gate that decides who may generate)
REVENUECAT_SECRET_API_KEY=
REVENUECAT_ENTITLEMENT_IDENTIFIER=

# Optional: daily spend cap in USD (defaults to 25 when unset)
V3_DAILY_SPEND_CAP_USD=25
