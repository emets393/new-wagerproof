# WagerProof Web App - Environment Variables
# Copy this file to .env and fill in values

# Supabase (Main Instance - auth, user data, AI, agents)
VITE_SUPABASE_URL=https://gnjrklxotmbvnxbnnqgq.supabase.co
VITE_SUPABASE_ANON_KEY=

# RevenueCat (subscription management)
VITE_REVENUECAT_WEB_PUBLIC_API_KEY=
VITE_REVENUECAT_WEB_SANDBOX_API_KEY=

# Stripe (web payments)
VITE_STRIPE_PUBLISHABLE_KEY=

# The Odds API (real-time sportsbook odds)
VITE_THE_ODDS_API_KEY=

# Ghost CMS (blog content)
VITE_GHOST_URL=
VITE_GHOST_CONTENT_KEY=

# -----------------------------------------------------------
# Edge Function Secrets (set via: supabase secrets set KEY=VALUE)
# -----------------------------------------------------------
# SUPABASE_URL              - Main Supabase URL (auto-set)
# SUPABASE_SERVICE_ROLE_KEY - Main service role key (auto-set)
# SUPABASE_ANON_KEY         - Main anon key (auto-set)
# CFB_SUPABASE_URL          - CFB/sports predictions Supabase URL
# CFB_SUPABASE_ANON_KEY     - CFB instance anon key
# OPENAI_API_KEY            - OpenAI API (AI completions, agent generation)
# GOOGLE_AI_API_KEY         - Google Gemini API
# REVENUECAT_SECRET_API_KEY - RevenueCat webhook verification
# STRIPE_SECRET_KEY         - Stripe server-side
# LOOPS_API_KEY             - Loops email service
# FRONTEND_URL              - Frontend URL for callbacks
# INTERNAL_FUNCTION_SECRET  - Inter-function auth (V2 agent queue)
